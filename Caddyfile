# Local production mirror — routes /api, /django-admin, /static, /media to backend;
# everything else to the frontend SPA.
:80 {
    handle /api/* {
        reverse_proxy backend:8000
    }
    handle /django-admin/* {
        reverse_proxy backend:8000
    }
    handle /api-auth/* {
        reverse_proxy backend:8000
    }
    handle /static/* {
        reverse_proxy backend:8000
    }
    handle /media/* {
        reverse_proxy backend:8000
    }
    handle {
        reverse_proxy frontend:8080
    }
}