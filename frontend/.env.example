# Backend API base URL (Vite proxy handles /api → localhost:8000 in dev)
VITE_API_BASE_URL=http://localhost:8000

# Sentry DSN for error tracking (replace with your actual DSN)
VITE_SENTRY_DSN=https://your-dsn@sentry.io/1234567890

# Google Maps API key (replace with your actual API key)
VITE_GOOGLE_MAPS_API_KEY=your_api_key

# Google OAuth Client ID (replace with your actual OAuth client ID)
VITE_GOOGLE_CLIENT_ID=your_oauth_client_id
