# Backend API base URL
# Dev: Vite proxy handles /api → localhost:8000, so this can be http://localhost:8000
# Production (REQUIRED): set this to your deployed backend URL in the platform's env vars
#   e.g. VITE_API_BASE_URL=https://ptrack-api.onrender.com
# Without this set at build time, the frontend cannot reach the API and will show offline.
VITE_API_BASE_URL=http://localhost:8000

# Sentry DSN for error tracking (replace with your actual DSN)
VITE_SENTRY_DSN=https://your-dsn@sentry.io/1234567890

# Google Maps API key (replace with your actual API key)
VITE_GOOGLE_MAPS_API_KEY=your_api_key

# Google Maps Map ID (replace with your actual Map ID)
VITE_GOOGLE_MAPS_MAP_ID=your_map_id

# Google OAuth Client ID (replace with your actual OAuth client ID)
VITE_GOOGLE_CLIENT_ID=your_oauth_client_id

# VAPID public key for push notifications (replace with your actual VAPID public key)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key