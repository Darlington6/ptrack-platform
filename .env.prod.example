# Copy to .env.prod and fill in real values before running docker-compose.prod.yml
# Never commit .env.prod — it is gitignored.
#
# Generate a SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# Run command:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up --build

# Django
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Neon or any Postgres URL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis
REDIS_URL=redis://redis:6379/0

# CORS — set to your frontend origin
CORS_ALLOWED_ORIGINS=http://localhost

# Cloudinary (optional — set USE_CLOUDINARY=True to enable)
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sentry
SENTRY_DSN=

# Resend (email)
RESEND_API_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Vite build-time env vars (used by docker-compose.prod.yml build args)
VITE_API_BASE_URL=http://localhost
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_CLIENT_ID=
VITE_SENTRY_DSN=