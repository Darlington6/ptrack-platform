# Django settings
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Default: SQLite (no config needed — just leave DATABASE_URL blank or use the line below)
DATABASE_URL=sqlite:///db.sqlite3

# To switch to PostgreSQL on Railway, replace with:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Sentry DSN for error tracking (replace with your actual DSN)
SENTRY_DSN=https://your-dsn@sentry.io/1234567890

# Application version for Sentry release tracking
APP_VERSION=1.0.0

# Brevo API key for transactional email (get from https://app.brevo.com/settings/keys/api)
BREVO_API_KEY=your-brevo-api-key
# Sender address — must match the verified sender you configure in Brevo (Settings → Senders & Domains)
DEFAULT_FROM_EMAIL=pTrack <your-verified-sender@example.com>

# Google Maps API key (replace with your actual API key)
GOOGLE_MAPS_API_KEY=your_api_key

# Google OAuth Client ID (replace with your actual OAuth client ID)
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id

# Google OAuth Client Secret (replace with your actual OAuth client secret)
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret

# Cloudinary configuration for image uploads (replace with your actual credentials)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Set to True to enable Cloudinary storage for media files (requires valid Cloudinary credentials)
USE_CLOUDINARY=False

# Redis URL for caching and session storage
# Local dev: leave blank (Django falls back to database caching automatically)
# Production (Render): set to the Internal Redis URL from your Key Value service
REDIS_URL=redis://localhost:6379/0